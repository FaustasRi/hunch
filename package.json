{
  "name": "hunch-mcp",
  "version": "0.0.0",
  "description": "Hunch — talk to Claude (or Codex) about Kalshi prediction markets and place trades by conversation. Demo-by-default, safety-first MCP server.",
  "type": "module",
  "license": "MIT",
  "author": "Faustas Rinkevicius (@FaustasRi)",
  "homepage": "https://github.com/FaustasRi/hunch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FaustasRi/hunch.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "kalshi",
    "prediction-markets",
    "claude",
    "trading"
  ],
  "bin": {
    "hunch-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:ci": "node scripts/test-ci.mjs",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.0"
  }
}
