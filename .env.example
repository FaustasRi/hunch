# ─── Hunch configuration ────────────────────────────────────────────────────
# Copy to `.env` for local dev. In production, prefer macOS Keychain (see AGENTS.md).
# .env is gitignored. NEVER commit a real private key.

# Environment: "demo" (fake money, default) or "live" (REAL MONEY).
# Going live requires TWO conscious acts: set this to "live" AND provide a live key.
KALSHI_ENV=demo

# Kalshi API credentials (generate at kalshi.com/account/profile → Create New API Key).
# Demo keys are generated separately at demo.kalshi.co — they are NOT interchangeable with prod.
KALSHI_API_KEY_ID=
# Path to the RSA private key PEM file Kalshi gave you at key creation (shown once).
KALSHI_PRIVATE_KEY_PATH=./kalshi-demo-key.pem
# Alternatively, inline the PEM (overrides the path if set). Keep out of git.
# KALSHI_PRIVATE_KEY=

# ─── Safety caps (enforced server-side, in code — reject, never clamp) ───────
# Dollar amounts. Apply in BOTH demo and live. Raise consciously.
MAX_ORDER_USD=25
MAX_DAILY_USD=100
MAX_OPEN_EXPOSURE_USD=250

# Third, explicit act to fully uncap (only honored together with KALSHI_ENV=live).
DISABLE_LIMITS=false

# Allow sports event contracts (legality is US-state-dependent — see ADR-0003).
ALLOW_SPORTS=false

# Append-only audit log path (JSONL). Every proposed/placed/cancelled order + fill.
AUDIT_LOG_PATH=./audit-log.jsonl
